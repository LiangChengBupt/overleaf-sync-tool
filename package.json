{
  "name": "overleaf-sync",
  "version": "1.0.0",
  "description": "CLI tool to sync local and remote Overleaf repositories",
  "author": "iamhyc",
  "license": "MIT",
  "main": "dist/index.js",
  "bin": {
    "ov": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "postinstall": "node ./scripts/patch-socketio-client.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "overleaf",
    "sync",
    "cli",
    "latex"
  ],
  "dependencies": {
    "commander": "^11.1.0",
    "diff-match-patch": "^1.0.5",
    "form-data": "^4.0.0",
    "mime-types": "^2.1.35",
    "minimatch": "^9.0.9",
    "node-fetch": "^2.7.0",
    "socket.io-client": "github:overleaf/socket.io-client#0.9.17-overleaf-5",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/diff-match-patch": "^1.0.34",
    "@types/node": "^20.2.5",
    "@types/node-fetch": "^2.6.11",
    "@types/socket.io-client": "^1.4.36",
    "typescript": "^5.1.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
